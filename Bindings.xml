<Bindings>
	<Binding name="TRINKETMENU_TOGGLE" header="TRINKETMENU">
		TrinketMenu.ToggleFrame(TrinketMenuOptions.DisableToggle=="ON" and TrinketMenu_OptFrame or TrinketMenu_MainFrame)
	</Binding>
	<Binding name="TRINKETMENU_USE_TOP">
		UseInventoryItem(13)
	</Binding>
	<Binding name="TRINKETMENU_USE_BOTTOM">
		UseInventoryItem(14)
	</Binding>
</Bindings>